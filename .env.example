# AI provider — "gemini" (default, free) or "claude"
AI_PROVIDER=gemini

# Gemini API key (Google AI Studio — free)
GEMINI_API_KEY=your_gemini_api_key_here

# Claude API key (only needed if AI_PROVIDER=claude)
CLAUDE_API_KEY=your_claude_api_key_here

# Firebase project config (web app — these are public/safe to commit)
# Get from Firebase Console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
